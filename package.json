{
    "name": "nexora",
    "version": "0.1.0",
    "private": true,
    "description": "Modern fashion ecommerce built with Next.js, NestJS, PostgreSQL and Prisma.",
    "scripts": {
        "dev": "pnpm --parallel --filter web --filter api dev",
        "dev:web": "pnpm --filter web dev",
        "dev:api": "pnpm --filter api dev",
        "build": "pnpm -r build",
        "lint": "pnpm -r lint",
        "test": "pnpm -r test",
        "prisma:push": "pnpm --filter api exec prisma db push",
        "prisma:generate": "pnpm --filter api exec prisma generate",
        "prisma:studio": "pnpm --filter api exec prisma studio"
    },
        "engines": {
            "node": ">=22.0.0",
            "pnpm": ">=10.0.0"
        },
    "packageManager": "pnpm@10.0.0"
}